{#
  Button macro
  Usage:
    {% from "macros/button.njk" import button %}
    {{ button("Click me", { variant: "primary", size: "lg", href: "/page/" }) }}
    {{ button("Delete", { variant: "destructive", icon: "trash-2" }) }}

  Options:
    variant  — primary (default), secondary, outline, ghost, destructive
    size     — xs, sm, (default), lg, icon
    href     — if set, renders <a> instead of <button>
    icon     — Lucide icon name (renders before label)
    iconOnly — if true, uses icon size and hides label visually
    attrs    — extra HTML attributes string
#}

{% macro button(label, opts) %}
  {%- set variant = opts.variant or "primary" -%}
  {%- set size = opts.size or "" -%}
  {%- set href = opts.href or "" -%}
  {%- set icon = opts.icon or "" -%}
  {%- set iconOnly = opts.iconOnly or false -%}
  {%- set attrs = opts.attrs or "" -%}

  {%- set classes = "btn btn--" + variant -%}
  {%- if size %}{%- set classes = classes + " btn--" + size -%}{% endif -%}
  {%- if iconOnly %}{%- set classes = classes + " btn--icon" -%}{% endif -%}

  {%- if href -%}
    <a href="{{ href }}" class="{{ classes }}" {{ attrs | safe }}>
      {%- if icon %}<i data-lucide="{{ icon }}" style="width:1em;height:1em;"></i>{% endif -%}
      {%- if not iconOnly %}
        {{ label }}
      {% else %}
        <span class="sr-only">{{ label }}</span>
      {% endif -%}
    </a>
  {%- else -%}
    <button class="{{ classes }}" {{ attrs | safe }}>
      {%- if icon %}<i data-lucide="{{ icon }}" style="width:1em;height:1em;"></i>{% endif -%}
      {%- if not iconOnly %}
        {{ label }}
      {% else %}
        <span class="sr-only">{{ label }}</span>
      {% endif -%}
    </button>
  {%- endif -%}
{% endmacro %}
