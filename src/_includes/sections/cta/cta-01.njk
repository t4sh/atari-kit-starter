{# CTA — Standard (cta-01) #}
<section class="section" data-observe="reveal-up" style="background: var(--surface-container);">
  <div class="container" style="text-align: center; max-width: 640px;">
    <h2 style="margin-bottom: var(--space-4);">{{ ctaTitle or "Ready to get started?" }}</h2>
    <p
      style="font-size: var(--text-lg); color: var(--on-surface-variant); margin-bottom: var(--space-8);"
    >
      {{ ctaDescription or "Join us and start building your next prototype today." }}
    </p>
    <div class="flex-center" style="gap: var(--space-4);">
      {% from "macros/button.njk" import button %}
      {{ button(ctaButtonText or "Get Started", { variant: "primary", href: ctaButtonHref or "#" }) }}
    </div>
  </div>
</section>
