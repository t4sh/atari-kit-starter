{# Hero — Default (hero-01) #}
<section class="section--lg" data-observe="reveal-up" style="background: var(--surface);">
  <div class="container" style="text-align: center; max-width: 768px;">
    <h1 style="margin-bottom: var(--space-6);">{{ heroTitle or "Build something remarkable" }}</h1>
    <p
      style="font-size: var(--text-xl); color: var(--on-surface-variant); margin-bottom: var(--space-8);"
    >
      {{ heroSubtitle or "A design-system-agnostic prototype built with Eleventy, Tailwind v4, and vanilla JavaScript." }}
    </p>
    <div class="flex-center" style="gap: var(--space-4); flex-wrap: wrap;">
      {% from "macros/button.njk" import button %}
      {{ button("Get Started", { variant: "primary", size: "lg", href: "#" }) }}
      {{ button("Learn More", { variant: "outline", size: "lg", href: "/about/" }) }}
    </div>
  </div>
</section>
