<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" id="meta-theme-color" content="oklch(0.985 0 0)" />
    <meta name="view-transition" content="same-origin" />

    <title>{{ title or site.name }}</title>
    <meta name="description" content="{{ description or site.description }}" />

    {# -- Favicon (simple text-based for now) -------------------------------- #}
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%E2%97%86%3C/text%3E%3C/svg%3E"
      type="image/svg+xml"
    />

    {# -- Prevent flash: apply dark class before paint ----------------------- #}
    <script>
      (function () {
        var p = localStorage.getItem('theme-preference') || 'system';
        var dark =
          p === 'dark' ||
          (p === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        if (dark) document.documentElement.classList.add('dark');
        var m = document.querySelector('#meta-theme-color');
        if (m) m.content = dark ? 'oklch(0.15 0 0)' : 'oklch(0.985 0 0)';
      })();
    </script>

    {# -- Fonts: preconnect + Google Fonts (Neometric stack) ----------------- #}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preconnect" href="https://unpkg.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hubot+Sans:wght@200..900&family=Inter+Tight:wght@400;500;600;700;800;900&family=Instrument+Serif&family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {# -- Tailwind v4 Browser Build ------------------------------------------ #}
    {#
      IMPORTANT: @theme values are evaluated by the TW4 JIT at parse time,
      before tokens.css (loaded via <link> below) is available. That means
      var(--token) refs here CANNOT resolve and will break utility generation
      for any non-color namespace. Rule of thumb:

        - Fonts, type scale, spacing base, radii, shadows → literal values
        - Color tokens → var(--token) is fine (Tailwind emits
          `.bg-primary { background: var(--primary) }`, which resolves at
          render time, not JIT time)

      Keep light-mode values here; dark-mode overrides live in tokens.css via
      the `html.dark` cascade and apply at runtime.
    #}
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
      @layer base, components, utilities;

      @theme {
        /* -- Fonts (literals matching tokens.css) -- */
        --font-sans: 'Space Grotesk', sans-serif;
        --font-heading: 'Inter Tight', sans-serif;
        --font-body: 'Hubot Sans', 'Inter Tight', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
        --font-serif: 'Instrument Serif', Georgia, serif;

        /* -- Type scale (drives text-2xs/xs/sm/base/lg/xl/...) -- */
        --text-2xs: 0.6875rem;
        --text-xs: 0.75rem;
        --text-sm: 0.875rem;
        --text-base: 1rem;
        --text-lg: 1.125rem;
        --text-xl: 1.25rem;
        --text-2xl: 1.5rem;
        --text-3xl: 1.875rem;
        --text-4xl: 2.25rem;
        --text-5xl: 3rem;

        /* -- Spacing base (drives p-N, m-N, gap-N via TW4 calc multiplier).
           tokens.css --space-N values are exact 0.25rem multiples, so
           `p-5` === `var(--space-5)` === 1.25rem. */
        --spacing: 0.25rem;

        /* -- Surface system -- */
        --color-surface: var(--surface);
        --color-surface-dim: var(--surface-dim);
        --color-surface-bright: var(--surface-bright);
        --color-surface-container-lowest: var(--surface-container-lowest);
        --color-surface-container-low: var(--surface-container-low);
        --color-surface-container: var(--surface-container);
        --color-surface-container-high: var(--surface-container-high);
        --color-surface-container-highest: var(--surface-container-highest);
        --color-on-surface: var(--on-surface);
        --color-on-surface-variant: var(--on-surface-variant);

        /* -- Color roles -- */
        --color-primary: var(--primary);
        --color-on-primary: var(--on-primary);
        --color-primary-container: var(--primary-container);
        --color-secondary: var(--secondary);
        --color-on-secondary: var(--on-secondary);
        --color-tertiary: var(--tertiary);
        --color-on-tertiary: var(--on-tertiary);
        --color-error: var(--error);
        --color-on-error: var(--on-error);

        /* -- Outline -- */
        --color-outline: var(--outline);
        --color-outline-variant: var(--outline-variant);

        /* -- Shadows (numeric 1..5 is the project convention;
           dark-mode values in tokens.css via html.dark cascade) -- */
        --shadow-1: 0 1px 3px 1px oklch(0 0 0 / 0.08), 0 1px 2px oklch(0 0 0 / 0.1);
        --shadow-2: 0 2px 6px 2px oklch(0 0 0 / 0.08), 0 1px 2px oklch(0 0 0 / 0.1);
        --shadow-3: 0 4px 8px 3px oklch(0 0 0 / 0.08), 0 1px 3px oklch(0 0 0 / 0.1);
        --shadow-4: 0 6px 10px 4px oklch(0 0 0 / 0.08), 0 2px 3px oklch(0 0 0 / 0.1);
        --shadow-5: 0 8px 12px 6px oklch(0 0 0 / 0.08), 0 4px 4px oklch(0 0 0 / 0.1);

        /* -- Radii -- */
        --radius-xs: 0.25rem;
        --radius-sm: 0.5rem;
        --radius-md: 0.75rem;
        --radius-lg: 1rem;
        --radius-xl: 1.5rem;
        --radius-full: 9999px;

        /* -- Motion / duration (drives duration-* / ease-* utilities) -- */
        --duration-fast: 150ms;
        --duration-normal: 250ms;
        --duration-slow: 400ms;
        --duration-slower: 600ms;
        --ease-standard: cubic-bezier(0.2, 0, 0, 1);
        --ease-decelerate: cubic-bezier(0, 0, 0, 1);
        --ease-accelerate: cubic-bezier(0.3, 0, 1, 1);
      }
    </style>

    {# -- CSS files ---------------------------------------------------------- #}
    <link rel="stylesheet" href="/assets/css/tokens.css" />
    <link rel="stylesheet" href="/assets/css/base.css" />
    <link rel="stylesheet" href="/assets/css/components.css" />
    <link rel="stylesheet" href="/assets/css/utilities.css" />

    {# -- Lucide Icons CDN --------------------------------------------------- #}
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  </head>

  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    {{ content | safe }}

    {# -- JS modules (deferred) --------------------------------------------- #}
    <script defer src="/assets/js/observer.js"></script>
    <script defer src="/assets/js/theme-toggle.js"></script>
    <script defer src="/assets/js/view-transitions.js"></script>
    <script defer src="/assets/js/icons.js"></script>
    <script defer src="/assets/js/mobile-menu.js"></script>
  </body>
</html>
