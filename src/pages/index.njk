{# -- Feature cards --------------------------------------------------------- #}
<section class="section" data-observe="stagger" style="background: var(--surface);">
  <div class="container">
    <h2 style="text-align: center; margin-bottom: var(--space-12);" data-observe="reveal-up">
      Built for prototyping
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="card" data-observe="reveal-up" style="--stagger-index: 0;">
        <div style="margin-bottom: var(--space-4); color: var(--primary);">
          <i data-lucide="layers" style="width: 2rem; height: 2rem;"></i>
