        </div>
        <h3 style="font-size: var(--text-xl); margin-bottom: var(--space-2);">Motion-Aware</h3>
        <p style="color: var(--on-surface-variant);">
          Respects prefers-reduced-motion. Single IntersectionObserver. View Transitions API.
        </p>
      </div>
    </div>
  </div>
</section>

